{
  "$comment": "Все параметры стратегии Smart Flow Momentum (Fasol edition). Агент читает этот файл в начале каждой сессии. Меняй значения здесь, а не в промптах.",
  "api": {
    "base_url": "https://api.fasol.trade/trading_bot/agent",
    "env_file": "~/.config/fasol/.env"
  },
  "budget": {
    "total_sol": 0.1,
    "reserve_sol": 0.05
  },
  "position": {
    "size_sol": 0.025,
    "max_concurrent": 2,
    "max_entries_per_day": 4,
    "slippage_cap_pct": 3
  },
  "scan": {
    "min_liquidity_usd": 30000,
    "max_token_age_hours": 72,
    "require_migrated": true,
    "shortlist_limit": 5,
    "max_heavy_calls_per_cycle": 1
  },
  "cadence": {
    "$comment": "Двухуровневый цикл. watch_tick — лёгкий (SSE-стрим или один live_trades), full_cycle — тяжёлый (snapshot/scan + полный vet). Ежеминутный full cycle запрещён: забьёт heavy tier (5 rpm) и контекст агента.",
    "watch_tick_minutes": 3,
    "full_cycle_minutes": 20,
    "prefer_sse_stream": true,
    "sse_endpoint": "tracked_wallet_trade_stream",
    "hot_signal_triggers_full_vet": true,
    "hot_signal_min_tracked_buyers": 2,
    "hot_signal_window_minutes": 15,
    "report_only_on_events": true
  },
  "smart_flow": {
    "tracked_wallets_target": 15,
    "wallet_search_lookback_days": 14,
    "refresh_tracked_wallets_days": 7,
    "min_tracked_buyers_1h": 2
  },
  "filters": {
    "require_migrated": true,
    "max_top10_holder_pct": 30,
    "max_dev_hold_pct": 5,
    "max_snipers_hold_pct": 20,
    "max_bundlers_hold_pct": 20,
    "max_bot_traders_hold_pct": 25,
    "max_1h_pump_pct": 400,
    "dev_serial_rugger": {
      "min_launched_count": 10,
      "max_migrated_pct": 20
    },
    "require_socials_or_dexpaid": true,
    "reject_mayhem_mode": true,
    "max_sell_to_buy_tx_ratio": 2,
    "require_tracked_wallets_net_buying_1h": true
  },
  "exits": {
    "take_profit_pct": 80,
    "take_profit_sell_portion_pct": 50,
    "trailing_stop_pct": 25,
    "trailing_stop_tightened_pct": 15,
    "trailing_activation_pct": 0,
    "tighten_trigger_gain_pct": 50,
    "time_stop_hours": 12,
    "time_stop_flat_range_pct": [-10, 15],
    "cancel_orders_on_manual_exit": true
  },
  "costs": {
    "assumed_round_trip_pct": 15,
    "measured_round_trip_pct": null,
    "$comment_costs": "Замерь реальный круг тестовым свопом 0.005 SOL (SETUP.md §6) и впиши measured_round_trip_pct"
  },
  "risk": {
    "hard_stop_balance_sol": 0.07,
    "max_realized_losses_per_day": 2,
    "weekly_review_min_trades": 20
  },
  "backtest": {
    "run_alert_simulate_before_first_trade": true,
    "min_median_ath_multiplier": 1.3,
    "simulate_days": 3
  },
  "scaling": [
    { "min_balance_sol": 0.15, "size_sol": 0.03, "max_concurrent": 3 },
    { "min_balance_sol": 0.25, "size_pct_of_balance": 4.5, "min_reserve_pct": 40 }
  ]
}
